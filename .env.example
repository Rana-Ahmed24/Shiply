# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser (webhooks, admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL used in verification emails and OAuth redirects.
# MUST be reachable by anyone clicking email links (not localhost for remote testers).
# Examples: https://your-app.vercel.app  or  https://abc123.ngrok-free.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Also configure in Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: same as NEXT_PUBLIC_SITE_URL (production URL when inviting others)
# - Redirect URLs: http://localhost:3000/**  AND  https://your-production-domain/**
# Email template: see supabase/scripts/email-template-confirm-signup.html

# Signup emails: Supabase free tier sends ~2 verification emails/hour per project.
# If signups fail with "email rate limit", wait up to 1 hour, use custom SMTP in Supabase,
# or disable "Confirm email" under Authentication → Providers → Email (dev only).

# Request package photos bucket (must match Supabase Storage bucket id)
NEXT_PUBLIC_REQUEST_IMAGES_BUCKET=request-images

# Chat image attachments bucket (must match Supabase Storage bucket id)
NEXT_PUBLIC_CHAT_IMAGES_BUCKET=chat-images

# Google OAuth: users may see "continue to YOUR_PROJECT.supabase.co" — that is normal.
# To show your app name/domain instead, set Google Cloud OAuth consent screen app name
# (APIs & Services → OAuth consent screen) and optionally Supabase custom auth domain.
